# ── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# ── Environment ────────────────────────────────────────────
# Never commit real secrets. .env.example + .env.local-stub stay tracked.
.env
.env.*
!.env.example
!.env.*.example
!.env.local-stub

# ── Frontend build artifacts (TanStack Start / Nitro / Vite) ─
.output/
.nitro/
.tanstack/
.vinxi/
.vite/
.wrangler/
dist/
build/

# ── Backend ────────────────────────────────────────────────
# Prisma generated client is regenerated via `bun run db:generate`
backend/prisma/generated/

# ── Sui Move ───────────────────────────────────────────────
# Move build output. Move.lock IS committed (it pins on-chain deps).
contracts/**/build/

# ── Logs ───────────────────────────────────────────────────
*.log
npm-debug.log*
bun-debug.log*
logs/

# ── Testing / coverage ─────────────────────────────────────
coverage/
.nyc_output/

# ── Local Claude config (project context like progress.md stays tracked) ─
**/.claude/settings.local.json

# ── Editor / OS cruft ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
*.swp
*.swo
.idea/
*.iml

# ── Misc ───────────────────────────────────────────────────
*.local
.cache/
.temp/
.tmp/

# ── Remotion launch video (heavy asset workspace, not part of the app) ─
# remotion/

# ── BigDev autonomous build loop ───────────────────────────
# plans/, TODO.md, the scripts, and requirements-log.md ARE tracked (project memory).
# Only the transient runtime artifacts are ignored.
bigdev/claude/auto-build-logs/
bigdev/claude/auto-build.lock
bigdev/claude/inject.md

# ── BigDev autonomous review loop ──────────────────────────
# plans/review/, REVIEW-TODO.md, the scripts, and review-requirements-log.md ARE
# tracked (project memory). Only transient runtime artifacts are ignored.
bigdev/claude/auto-review-logs/
bigdev/claude/auto-review.lock
bigdev/claude/review-inject.md
bigdev/claude/review-state.json
bigdev/claude/review-dirty.json
bigdev/claude/audit-cache/
bigdev/e2e-screenshots/