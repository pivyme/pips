# ── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# ── Environment ────────────────────────────────────────────
# Never commit real secrets. .env.example files stay tracked.
.env
.env.*
!.env.example
!.env.*.example

# ── Frontend build artifacts (TanStack Start / Nitro / Vite) ─
.output/
.nitro/
.tanstack/
.vinxi/
.vite/
.wrangler/
dist/
build/

# ── Backend ────────────────────────────────────────────────
# Prisma generated client is regenerated via `bun run db:generate`
backend/prisma/generated/

# ── Sui Move ───────────────────────────────────────────────
# Move build output. Move.lock IS committed (it pins on-chain deps).
contracts/**/build/

# ── Logs ───────────────────────────────────────────────────
*.log
npm-debug.log*
bun-debug.log*
logs/

# ── Testing / coverage ─────────────────────────────────────
coverage/
.nyc_output/

# ── Local Claude config (project context like progress.md stays tracked) ─
**/.claude/settings.local.json

# ── Editor / OS cruft ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
*.swp
*.swo
.idea/
*.iml

# ── Misc ───────────────────────────────────────────────────
*.local
.cache/
.temp/
.tmp/
