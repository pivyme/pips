# ===========================================
# PIPS - Frontend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ===========================================
# App Configuration
# ===========================================
VITE_APP_NAME="PIPS"
VITE_APP_URL="http://localhost:3200"

# ===========================================
# API Configuration
# ===========================================
VITE_API_URL="http://localhost:3780"

# ===========================================
# Demo mode
# ===========================================
# true = run the whole app on an in-memory mock (no backend, no Sui, play money).
# Lets anyone play the full UI with zero setup. A toggle on the landing page can
# override this per-device. Default false (real backend + Predict).
VITE_DEMO_MODE="false"

# ===========================================
# Access gate (private test deploy)
# ===========================================
# true = tapping START asks for VITE_ACCESS_CODE before letting anyone in, remembered per-device.
# Soft gate only (the code ships in the client bundle), just enough to keep the public out while
# testing. Leave "false" for a normal open deploy.
VITE_ACCESS_GUARD="false"
VITE_ACCESS_CODE=""

# ===========================================
# Sui
# ===========================================
# testnet (default) | mainnet. We trade Mysten's real DeepBook Predict; the Predict ids are committed
# in the backend deploy record, so the browser just needs the network + fullnode. Keep VITE_DEMO_MODE=false to play for real.
VITE_SUI_NETWORK="testnet"
# The fullnode RPC the browser reads over.
VITE_SUI_FULLNODE_URL="https://fullnode.testnet.sui.io:443"

# Cross-chain deposit signing. "true" wires Privy's MetaMask/Phantom connectors so a bridge deposit can be
# signed. Off by default so the Google + embedded-Sui login is untouched; flip on the mainnet deploy (and
# toggle the connectors on in the Privy dashboard). The execute gate itself is server-owned, this only
# enables the connect UI, so a testnet build is never one flag away from moving real money.
VITE_BRIDGE_EXECUTE="false"

# ===========================================
# Auth mode + Privy
# ===========================================
# dev = auto-login the testing wallet (the build loop default). privy = Google/email login with a
# non-custodial embedded Sui wallet. Mirror the backend PIPS_AUTH_MODE.
VITE_AUTH_MODE="dev"
# Debug onboarding: force every sign-in (and reload) through the full handle/skin/welcome arc,
# even for accounts that already onboarded. Leave "false" outside of debugging the flow.
VITE_ONBOARDING_DEBUG="false"
# Privy app id (public) from dashboard.privy.io, with embedded Sui wallets + Google/email enabled.
# This is the SAME value as backend/.env PRIVY_APP_ID (it is a public client id, safe to commit).
VITE_PRIVY_APP_ID="cmqk56bzv004m0ejvw2qbq0vw"
# The session-signer key-quorum id the user delegates to so the server can sign plays popup-free.
# This is the SAME value as backend/.env PRIVY_AUTHORIZATION_KEY_ID.
VITE_PRIVY_SESSION_SIGNER_ID="b01z9wafxfmu5ocfw16kpwm4"

# ===========================================
# Analytics (optional)
# ===========================================
# VITE_GA_ID=""
# VITE_POSTHOG_KEY=""
