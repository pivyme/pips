# ===========================================
# Pips - Frontend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ===========================================
# App Configuration
# ===========================================
VITE_APP_NAME="Pips"
VITE_APP_URL="http://localhost:3200"

# ===========================================
# API Configuration
# ===========================================
VITE_API_URL="http://localhost:3700"

# ===========================================
# Demo mode
# ===========================================
# true = run the whole app on an in-memory mock (no backend, no Sui, play money).
# Lets anyone play the full UI with zero setup. A toggle on the landing page can
# override this per-device. Default false (real backend + Predict).
VITE_DEMO_MODE="false"

# ===========================================
# Sui
# ===========================================
# testnet | mainnet | devnet | localnet. Use "localnet" (with VITE_DEMO_MODE=false) to play
# against the local Predict instance from scripts/localnet.sh. localnet RPC defaults to :9000.
VITE_SUI_NETWORK="testnet"
# Override the default fullnode RPC. Point at a deployed localnet here, e.g. our node at
# https://rpc.playpips.fun. The browser needs a valid TLS cert on the host (a Traefik default
# self-signed cert is rejected). The /tools/wallet debug page can also override this per-device.
# VITE_SUI_FULLNODE_URL=""

# ===========================================
# Enoki (zkLogin) - phase 2, public client key
# ===========================================
# VITE_ENOKI_API_KEY=""

# ===========================================
# Analytics (optional)
# ===========================================
# VITE_GA_ID=""
# VITE_POSTHOG_KEY=""
