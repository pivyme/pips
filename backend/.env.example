APP_PORT=3780
NODE_ENV=development
DATABASE_URL="postgresql://postgres:admin@localhost:5432/<db-name>?schema=public"
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN=7d
ALLOWED_ORIGIN="https://your-frontend-url.com"

# Sui. We run on our OWN localnet (not testnet): the whole Predict stack on a Sui node with
# infinite faucet SUI. It's deployed and live at https://rpc.playpips.fun. Deploy/redeploy with
# scripts/localnet.sh (setup once, redeploy after a contracts/ change). A throwaway local node:
# scripts/localnet.sh up.
SUI_NETWORK=localnet
# Runtime fullnode RPC the app reads/plays over (JSON-RPC). The deployed localnet:
SUI_FULLNODE_URL="https://rpc.playpips.fun"
# The gRPC origin the sui CLI publishes through (Cloudflare 403s gRPC on the proxied url). The CDN
# hides the origin from DNS, so it's recorded here. scripts/localnet.sh uses it automatically.
PIPS_DEPLOY_RPC="http://95.111.237.44:9000"

# Money (localnet). All optional, sane defaults shown. Chips are the dusdc coin branded "USDC".
# Onboarding mints free chips once per user. The per-user SUI funding below is only used when gas
# sponsorship is OFF (no sponsor key); with a sponsor key, users never hold SUI.
# PIPS_STARTING_BALANCE=1000
# PIPS_GAS_FUND_SUI=1
# PIPS_GAS_MIN_SUI=0.2
#
# Gas sponsorship (privy mode): one dedicated wallet pays the gas for every user play via Sui
# address balances, so users hold only DUSDC and never need SUI. Generate a key with:
#   bun -e 'import {Ed25519Keypair} from "@mysten/sui/keypairs/ed25519"; const k=Ed25519Keypair.generate(); console.log(k.getSecretKey(), k.getPublicKey().toSuiAddress())'
# The operator seeds + tops up its balance from free localnet SUI on boot. Empty = sponsorship off
# (falls back to the per-user SUI funding above). MIN/TOPUP are the refill floor + amount in SUI.
# GAS_SPONSORSHIP_WALLET_PK="suiprivkey1..."
# PIPS_SPONSOR_MIN_SUI=50
# PIPS_SPONSOR_TOPUP_SUI=500

# Dedicated ops wallets (stability). Each duty gets its own gas coin so a slow one can't block the
# others. Generate both with: bun scripts/gen-ops-wallets.ts (writes them here-style into .env).
# Settlement: signs the permissionless redeem sweep, so a backed-up redeem can't head-of-line block
# the operator's price-push/nudge lane. Only USED on the operator; the operator auto-funds it (SUI).
# TREASURY: holds a big pre-minted DUSDC reserve and pays onboarding chips + the faucet via transfer,
# so DUSDC never comes off the operator key. Set the SAME treasury key on every backend. Empty keys
# fall back to the operator wallet (legacy single-wallet). All MIN/TOPUP have generous defaults.
# SETTLEMENT_WALLET_PK="suiprivkey1..."
# PIPS_SETTLEMENT_MIN_SUI=50
# PIPS_SETTLEMENT_TOPUP_SUI=500
# TREASURY_WALLET_PK="suiprivkey1..."
# PIPS_TREASURY_MIN_SUI=20
# PIPS_TREASURY_TOPUP_SUI=200
# PIPS_TREASURY_MIN_DUSDC=1000000
# PIPS_TREASURY_TOPUP_DUSDC=5000000
# Request DUSDC faucet: amount per tap + per-user cooldown (ms).
# PIPS_FAUCET_AMOUNT=100
# PIPS_FAUCET_COOLDOWN_MS=60000

# Auth mode: 'dev' (operator-signed, the build loop default) or 'privy' (non-custodial embedded
# Sui wallet, server-signed via a session signer). Demo mode is a separate web-only flag.
# PIPS_AUTH_MODE=dev

# Privy (privy mode only). Create the app at dashboard.privy.io, enable embedded Sui wallets +
# Google/email login, and an authorization key for session signers. App id is also set on the web.
# The authorization key has a private key (P-256 PKCS8, the dashboard hands it back prefixed with
# `wallet-auth:`) and a key-quorum id (the web's VITE_PRIVY_SESSION_SIGNER_ID). The private key
# signs each wallet API request so the server can rawSign plays; the id provisions/owns wallets.
# PRIVY_APP_ID=""
# PRIVY_APP_SECRET=""
# PRIVY_AUTHORIZATION_KEY_ID=""
# PRIVY_AUTHORIZATION_PRIVATE_KEY=""
# PRIVY_JWT_VERIFICATION_KEY=""
# Spike-only (Phase 12 gate, scripts/verify-privy.ts): optionally pin a browser-created Privy Sui
# wallet to sign for. Left unset, the spike provisions a server-owned wallet via the authorization
# key, so it runs fully headless.
# SPIKE_PRIVY_WALLET_ID=""
# SPIKE_PRIVY_PUBLIC_KEY=""
# SPIKE_PRIVY_ADDRESS=""