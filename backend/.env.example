APP_PORT=3700
NODE_ENV=development
DATABASE_URL="postgresql://postgres:admin@localhost:5432/<db-name>?schema=public"
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN=7d
ALLOWED_ORIGIN="https://your-frontend-url.com"

# Sui. `localnet` runs the whole Predict stack on a local node with infinite faucet SUI
# (no gas-starved testnet oracles). Bring it up with: scripts/localnet.sh up + bootstrap.
SUI_NETWORK=testnet
# Override the default fullnode RPC for SUI_NETWORK (localnet default is :9000). Point at a
# deployed localnet here, e.g. https://rpc.playpips.fun. Bun rejects self-signed certs, so the
# host needs a real TLS cert. Re-bootstrap against it: SUI_NETWORK=localnet SUI_FULLNODE_URL=...
# SUI_FULLNODE_URL=""

# Enoki (zkLogin / sponsored tx) - phase 2, server side key
# ENOKI_PRIVATE_API_KEY=""