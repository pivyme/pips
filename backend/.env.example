# Copy to .env. Required: DATABASE_URL, JWT_SECRET. Everything else has a sane default.

# ---- Core ----
APP_PORT=3780
NODE_ENV=development
DATABASE_URL="postgresql://postgres:admin@localhost:5432/pips?schema=public"
JWT_SECRET="change-me"
JWT_EXPIRES_IN=7d
# ALLOWED_ORIGIN=https://your-frontend.com   # prod CORS lock (comma-separated)

# ---- Sui (testnet / mainnet = Mysten's real DeepBook Predict). ----
SUI_NETWORK=testnet
SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443
PYTH_HERMES_URL=https://hermes.pyth.network
PIPS_LOGGER_PACKAGE_ID=          # optional pips_logger package. Empty = mint PTB unchanged.

# ---- Auth ----
PIPS_AUTH_MODE=dev            # dev | privy
TESTING_WALLET_PK=suiprivkey1...
# TESTING_TOKEN=              # dev-only auth bypass, leave unset in prod
# Privy (privy mode): dashboard.privy.io, embedded Sui wallets + Google/email + an authorization key.
# PRIVY_APP_ID=
# PRIVY_APP_SECRET=
# PRIVY_AUTHORIZATION_KEY_ID=
# PRIVY_AUTHORIZATION_PRIVATE_KEY=
# Native wallet-connect login (custodial play-wallet). ENCRYPTION_KEY = 32 bytes hex.
# PIPS_WALLET_AUTH_ENABLED=true
# PIPS_WALLET_ENCRYPTION_KEY=

# ---- Economy ----
# PIPS_STARTING_BALANCE=100
# PIPS_MIN_STAKE=1.5           # PIPS_MAX_STAKE=3

# ---- Ops wallets (hand-funded on testnet: transfer SUI/DUSDC to these; the boot log prints the addresses). ----
# GAS_SPONSORSHIP_WALLET_PK=suiprivkey1...   # pays gas for user plays (draws from its SUI address balance)
# SETTLEMENT_WALLET_PK=suiprivkey1...        # signs the redeem sweep
# TREASURY_WALLET_PK=suiprivkey1...          # holds the DUSDC reserve, pays chips + faucet
# PIPS_SPONSOR_MIN_SUI=50
# PIPS_SPONSOR_TOPUP_SUI=0.2

# ---- House rake (revenue). Unset PK or 0 edge = off. The revenue wallet also SIGNS referral claim ----
# ---- payouts, so hand-fund it with a little SUI for gas. ----
# REVENUE_WALLET_PK=suiprivkey1...
# PIPS_HOUSE_EDGE_BPS=150
# PIPS_HOUSE_EDGE_MIN_NET_USD=1.2

# ---- Referral revenue share. Referrers earn 25% of their referees' fees, claimed from the revenue ----
# ---- wallet. Gated by REVENUE_WALLET_PK (no rake = no rewards). ----
# PIPS_REFERRAL_SHARE_BPS=2500
# PIPS_REFERRAL_MIN_CLAIM_USD=1
# PIPS_RATE_LIMIT_REFERRAL_CLAIM_MAX=10

# ---- Avatar storage (S3 / Spaces). Unset = uploads off, letter-chip fallback. ----
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET_URL=https://your-bucket.sgp1.digitaloceanspaces.com
# S3_FOLDER_PREFIX=pips

# ---- Multichain deposit (LI.FI). Quoting works with no key and on any network: it is a read-only ----
# ---- mainnet route lookup, which is what makes the deposit drawer show real routes on testnet. The ----
# ---- key only buys a per-key rate limit instead of a per-IP one. ----
# LIFI_API_KEY=
# PIPS_LIFI_INTEGRATOR=pips
# PIPS_DEPOSIT_MIN_USD=3
# PIPS_DEPOSIT_HARD_MIN_USD=1
# PIPS_RATE_LIMIT_QUOTE_MAX=60
# Cross-chain deposit EXECUTION. Inert unless SUI_NETWORK=mainnet: bridged real USDC would arrive in a
# DUSDC economy as a different coin type, invisible to the balance. Setting this on testnet does nothing.
# PIPS_BRIDGE_EXECUTE_ENABLED=false
