APP_PORT=3700
NODE_ENV=development
DATABASE_URL="postgresql://postgres:admin@localhost:5432/<db-name>?schema=public"
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN=7d
ALLOWED_ORIGIN="https://your-frontend-url.com"

# Sui
SUI_NETWORK=testnet
# Optional: override the default fullnode RPC for SUI_NETWORK
# SUI_FULLNODE_URL=""

# Enoki (zkLogin / sponsored tx) - phase 2, server side key
# ENOKI_PRIVATE_API_KEY=""