# Pips env reference. This documents every var across both pillars.
# The real files live at backend/.env and web/.env. The bootstrap (and
# .env.local-stub) distribute dev defaults into both. Never commit real secrets.

# ============================================================
# backend/.env
# ============================================================
APP_PORT=3700
NODE_ENV=development
# PostgreSQL. Local default below; never run destructive Prisma commands.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pips?schema=public
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
# prod only: lock CORS to the frontend origin
ALLOWED_ORIGIN=https://your-frontend-url

# Auth + signing mode: 'dev' (auto-login the testing wallet, backend signs txs)
# or 'enoki' (Google zkLogin, client signs, backend sponsors gas).
PIPS_AUTH_MODE=dev
# Testnet key for the dev wallet AND the Predict operator (suiprivkey... or base64).
# TESTNET ONLY, treat as throwaway. Fund it with testnet SUI for gas + DUSDC for chips.
TESTING_WALLET_PK=
# Enoki server secret for sponsored (gasless) transactions. enoki mode only.
ENOKI_PRIVATE_API_KEY=
SUI_NETWORK=testnet
# optional fullnode RPC override (else the SDK default for the network)
SUI_FULLNODE_URL=
# Pyth Hermes endpoint for the oracle price-pusher (public, no key)
PYTH_HERMES_URL=https://hermes.pyth.network
# free DUSDC starting balance minted to each new user, display units
PIPS_STARTING_BALANCE=1000

# Predict instance ids, WRITTEN BY THE BOOTSTRAP. Do not hand-edit.
# Unstable pre-mainnet, read from here, never inline in code.
PREDICT_PACKAGE_ID=
PREDICT_REGISTRY_ID=
PREDICT_OBJECT_ID=
PREDICT_ADMIN_CAP_ID=

# ============================================================
# web/.env  (Vite, must be VITE_ prefixed, validated in src/env.ts)
# ============================================================
VITE_API_URL=http://localhost:3700
# mirror PIPS_AUTH_MODE so the UI shows the right door
VITE_AUTH_MODE=dev
# Enoki public key + Google OAuth client id (configured in the Enoki portal)
VITE_ENOKI_API_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_SUI_NETWORK=testnet
